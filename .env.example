# =============================================================================
# Bookmist — Variables de entorno
# Copiá este archivo como .env.local y completá los valores.
# (Las variables NEXT_PUBLIC_* quedan visibles en el navegador; el resto son
#  solo del servidor y NO se deben exponer.)
# =============================================================================

# --- Supabase ----------------------------------------------------------------
# Dashboard de Supabase -> Project Settings -> API
NEXT_PUBLIC_SUPABASE_URL="https://TU-PROYECTO.supabase.co"
NEXT_PUBLIC_SUPABASE_ANON_KEY="tu-anon-key"
# ⚠️ SECRETO. Solo servidor. Ignora RLS — nunca exponer al navegador.
SUPABASE_SERVICE_ROLE_KEY="tu-service-role-key"

# --- URL del sitio -----------------------------------------------------------
# En local: http://localhost:3000 — En producción: https://bookmist.com.ar
# Si esta variable no está seteada en Vercel, el código cae a
# https://bookmist.com.ar (ver src/lib/constants.ts) — de todas formas
# conviene setearla explícita en el proyecto de Vercel.
NEXT_PUBLIC_SITE_URL="http://localhost:3000"

# --- WhatsApp de Bookmist ------------------------------------------------------
# Formato internacional, solo dígitos (sin +, espacios ni guiones).
# Ej: 5491122334455  (54 = Argentina, 9 = celular, 11 = área, número)
NEXT_PUBLIC_WHATSAPP_NUMBER=""

# --- Datos de la marca (opcionales: tienen valores por defecto) --------------
NEXT_PUBLIC_STORE_NOMBRE="Bookmist"
NEXT_PUBLIC_STORE_EMAIL="hola@bookmist.ar"
NEXT_PUBLIC_INSTAGRAM_URL="https://www.instagram.com/bookmist.ar/"
NEXT_PUBLIC_INSTAGRAM_HANDLE="@bookmist.ar"
NEXT_PUBLIC_TIKTOK_URL="https://www.tiktok.com/@bookmist.ar"

# --- Envío -----------------------------------------------------------------
# El costo de envío ya no es una variable de entorno: se carga por zona en la
# tabla `zonas_envio` (Table Editor de Supabase, hasta que exista el panel de
# administración). Ver supabase/seed.sql para zonas de ejemplo.

# --- Email a Daniela (opcional: sin esto, el pedido igual se registra y se
# arma el link de WhatsApp) ----------------------------------------------
# Proveedor: "resend" (recomendado) o "smtp".
EMAIL_PROVIDER="resend"
# Email donde llegan los pedidos nuevos.
OWNER_EMAIL=""
# Remitente por defecto (debe estar verificado en Resend o en tu servidor SMTP).
EMAIL_FROM="Bookmist <pedidos@bookmist.com.ar>"
# Opcionales: remitente propio para avisos de pedido y para el cupón de
# bienvenida — si no se cargan, ambos caen a EMAIL_FROM.
EMAIL_FROM_PEDIDOS="Bookmist <pedidos@bookmist.com.ar>"
EMAIL_FROM_PROMOCIONES="Bookmist <promociones@bookmist.com.ar>"

# Si EMAIL_PROVIDER="resend":
RESEND_API_KEY=""

# Si EMAIL_PROVIDER="smtp":
SMTP_HOST=""
SMTP_PORT="587"
SMTP_USER=""
SMTP_PASS=""
SMTP_SECURE="false"   # "true" para puerto 465

# --- Instagram real en la home (Fase 6k) -------------------------------------
# El token/id de la cuenta se cargan en la tabla `configuracion` (no acá,
# porque el cron los reescribe cuando renueva el token). Esto solo protege
# la ruta del cron que hace esa renovación semanal — cualquier string
# random de 16+ caracteres sirve. Vercel la manda sola en el header
# Authorization al invocar el cron (Project Settings -> Cron Jobs).
CRON_SECRET=""

# --- SEO / Analytics (Fase 7) -------------------------------------------------
# Google Search Console -> Configuración -> Verificación de propiedad -> etiqueta
# HTML (solo el valor del atributo content, no la etiqueta completa). Sin esto,
# el sitio no muestra el meta tag de verificación.
GOOGLE_SITE_VERIFICATION=""
# Google Analytics -> Administrar -> Flujos de datos -> tu flujo web -> ID de
# métricas (empieza con "G-"). Sin esto, no se carga ningún script de Analytics
# (cero cookies de terceros hasta que se cargue este valor).
NEXT_PUBLIC_GA_MEASUREMENT_ID=""

# --- Mercado Pago (Checkout Pro) ---------------------------------------------
# Access token: panel de Mercado Pago -> Tus integraciones -> Credenciales.
# Sin esto, la opción de Mercado Pago no aparece en el checkout (solo
# transferencia/efectivo) — el sitio funciona igual. El checkout redirige al
# formulario hospedado de Mercado Pago (Checkout Pro), así que no hace falta
# ninguna clave pública del lado del cliente.
# ⚠️ SECRETO. Solo servidor.
MP_ACCESS_TOKEN=""
